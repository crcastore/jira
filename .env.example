# --- Jira Cloud ---
JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_EMAIL=you@example.com
# Create at https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=your_atlassian_api_token

# --- GitHub (optional; agent runs Jira-only if unset) ---
# Classic token with `repo` scope, or fine-grained token with Issues + Pull requests
# read/write on the repos you want to use. https://github.com/settings/tokens
GITHUB_TOKEN=
# Override for GitHub Enterprise Server:
# GITHUB_API_URL=https://github.example.com/api/v3

# --- LLM (OpenAI-compatible) ---
# For OpenAI:
#   LLM_BASE_URL=https://api.openai.com/v1
#   LLM_MODEL=gpt-4o-mini
#   LLM_API_KEY=sk-...
#
# For Ollama (local, must support tool-calling, e.g. llama3.1, qwen2.5, mistral-nemo):
#   LLM_BASE_URL=http://localhost:11434/v1
#   LLM_MODEL=llama3.1
#   LLM_API_KEY=ollama
#
# For Groq / OpenRouter / Together: set their base URL + key.
LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL=llama3.1
LLM_API_KEY=ollama
